    <!-- Teleoperated Target Person -->
    <model name='target_person'>
      <pose>-1.0 -0.5 1.0 0 0 0</pose>
      <static>0</static>
      <link name='link'>
        <inertial>
          <mass>80.0</mass>
          <inertia>
            <ixx>10.0</ixx>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyy>10.0</iyy>
            <iyz>0.0</iyz>
            <izz>10.0</izz>
          </inertia>
        </inertial>
        <collision name='target_person_collision'>
          <pose>0 0 -0.15 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.28</radius>
              <length>1.75</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name='red_person_visual'>
          <geometry>
            <mesh>
              <uri>moonwalk.dae</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </visual>
      </link>
      <plugin name='planar_move' filename='libgazebo_ros_planar_move.so'>
        <ros>
          <namespace>/</namespace>
          <remapping>cmd_vel:=/target_person/cmd_vel</remapping>
          <remapping>odom:=/target_person/odom</remapping>
        </ros>
        <update_rate>30</update_rate>
        <publish_rate>30</publish_rate>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>link</robot_base_frame>
        <covariance_x>0.0001</covariance_x>
        <covariance_y>0.0001</covariance_y>
        <covariance_yaw>0.01</covariance_yaw>
      </plugin>
    </model>

    <!-- Automatically Moving Obstacle Person -->
    <model name='moving_obstacle_person'>
      <pose>1.0 1.0 1.0 0 0 0</pose>
      <static>0</static>
      <link name='link'>
        <inertial>
          <mass>80.0</mass>
          <inertia>
            <ixx>10.0</ixx>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyy>10.0</iyy>
            <iyz>0.0</iyz>
            <izz>10.0</izz>
          </inertia>
        </inertial>
        <collision name='collision'>
          <pose>0 0 -0.15 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.28</radius>
              <length>1.75</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <mesh>
              <uri>moonwalk.dae</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </visual>
      </link>
      <plugin name='planar_move' filename='libgazebo_ros_planar_move.so'>
        <ros>
          <namespace>/</namespace>
          <remapping>cmd_vel:=/moving_obstacle/cmd_vel</remapping>
          <remapping>odom:=/moving_obstacle/odom</remapping>
        </ros>
        <update_rate>30</update_rate>
        <publish_rate>30</publish_rate>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>link</robot_base_frame>
      </plugin>
    </model>
